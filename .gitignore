# --- macOS / IDE / local env ---
.DS_Store
.idea/
.venv/
.claude/settings.local.json

# --- Local-only material (delivered out-of-band, never pushed) ---
/docs/
/n8n/
/n8n-workflows/
/files.master/

# --- Secrets (exact-name; *.example variants stay tracked) ---
**/graphwise-secrets.yaml
**/terraform.tfvars
**/n8n.txt

# --- Terraform run artifacts, anywhere ---
**/.terraform/
**/.terraform.lock.hcl
*.tfstate
*.tfstate.*
*.tfplan
crash.log

# --- License blobs (depth-agnostic; survives a parent-dir rename) ---
**/licenses/*
!**/licenses/README.txt

# --- Helm nested-subchart tarballs / lockfiles (silent-stale-tarball footgun) ---
**/Chart.lock
**/charts/*.tgz
# ...except the umbrella's own vendored deps, which ARE committed intentionally
!charts/graphwise-stack/charts/*.tgz

# --- workflow Postgres dumps: NEVER committed anywhere in the repo. The seed
#     lives only on the EC2 home root ($HOME/workflows-pg-dumpall-<date>-v<N>.sql)
#     -- scp'd up by the operator or made by create-workflows-dumpall.sh;
#     restore-workflows-dumpall.sh loads the newest. ---
**/workflows-pg-dumpall*.sql
**/n8n-pg-dumpall*.sql

# Refine platform-independent dist source archive — 153 MB, exceeds GitHub 100 MB hard limit
refine/*.zip

# local kubectl/command scratchpad (never commit)
/foo
